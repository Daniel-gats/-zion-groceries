# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Database (if using PostgreSQL/Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/zion_groceries
# OR Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# M-Pesa (Daraja API) - Safaricom Kenya
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=your_business_shortcode
MPESA_CALLBACK_URL=https://zion-groceries-azure.vercel.app/api/mpesa/callback
MPESA_ENVIRONMENT=production
# Environment: production for live Daraja, sandbox only for Safaricom test credentials

# Business Configuration
BUSINESS_PHONE=254745562238
BUSINESS_NAME=G-man Groceries
BUSINESS_EMAIL=info@gmangroceries.com
SHOP_LOCATION_LABEL=Croton Ridge Estate, Kenyatta Road / Theta, Juja
SHOP_LATITUDE=-1.1087
SHOP_LONGITUDE=37.0719

# Email (Optional - for order notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
